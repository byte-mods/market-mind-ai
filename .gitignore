# ─────────────────────────────────────────────────────────────────────────────
# Secrets — NEVER commit
# ─────────────────────────────────────────────────────────────────────────────
local.json
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.crt
secrets/
credentials.json

# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
ENV/
.tox/
.nox/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ─────────────────────────────────────────────────────────────────────────────
# Local databases / caches
# ─────────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
mongo-data/
chroma-data/

# ─────────────────────────────────────────────────────────────────────────────
# ML artifacts (checkpoints, pickles, embeddings, vector indexes)
# Whole directories are excluded; keep a .gitkeep if you want the dirs tracked.
# ─────────────────────────────────────────────────────────────────────────────
marketmind/models/
marketmind/vectordb/
*.pkl
*.pt
*.pth
*.bin
*.onnx
*.npz
*.npy
*.h5
*.ckpt
!.gitkeep

# ─────────────────────────────────────────────────────────────────────────────
# Logs / temp
# ─────────────────────────────────────────────────────────────────────────────
*.log
logs/
tmp/
.tmp/

# ─────────────────────────────────────────────────────────────────────────────
# OS / editor
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code agent state (private to your machine)
# ─────────────────────────────────────────────────────────────────────────────
.claude/state/

# ─────────────────────────────────────────────────────────────────────────────
# Graphify generated intermediates (keep graph.json + GRAPH_REPORT.md + html)
# ─────────────────────────────────────────────────────────────────────────────
graphify-out/.graphify_*
graphify-out/cache/
graphify-out/memory/

# ─────────────────────────────────────────────────────────────────────────────
# Quarantined legacy code (PySide6 desktop UI — superseded by web UI)
# ─────────────────────────────────────────────────────────────────────────────
_legacy/

# ─────────────────────────────────────────────────────────────────────────────
# Node / frontend artifacts (if ever introduced)
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.next/
.turbo/
.lens/
