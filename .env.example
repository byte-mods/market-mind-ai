# ─────────────────────────────────────────────────────────────────────────────
# MarketMind AI — environment template
# Copy to `.env` (gitignored) and fill in real values, OR put them in
# `local.json` (also gitignored). Env vars take precedence over local.json.
# ─────────────────────────────────────────────────────────────────────────────

# ── Zerodha Kite Connect (required for live data) ───────────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ── Anthropic Claude API (required for chat / research / debate / RAG) ──────
ANTHROPIC_API_KEY=

# ── MongoDB (required — caches, lots ledger, alt-data, RL signals) ──────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=marketmind

# ── LLM router (optional — defaults to claude_api) ──────────────────────────
# Options: claude_cli | claude_api | deepseek | groq | ollama | openai
LLM_BACKEND=claude_api
LLM_MODEL_RESEARCH=claude-opus-4-7
LLM_MODEL_DEBATE=claude-sonnet-4-6
LLM_MODEL_CLASSIFY=claude-haiku-4-5

# Optional cheap-provider keys (only needed if LLM_BACKEND set to one of these)
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# ── Server ──────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info
